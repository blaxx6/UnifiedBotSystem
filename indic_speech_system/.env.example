# .env.example — Copy to .env and fill in your values
# ──────────────────────────────────────────────────────

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Evolution API for WhatsApp
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE_NAME=indic_speech_bot

# Phone numbers (JID format: countrycode+number@s.whatsapp.net)
BOT_PHONE_NUMBER=919876543210@s.whatsapp.net
OWNER_PHONE_NUMBER=919876543211@s.whatsapp.net

# Server settings
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PORT=3000
PYTHONPATH=.

# Cloud LLM fallback keys (optional — used when Ollama is down)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model Selection (optional — defaults shown)
# AI_MODEL=llama3.1:8b
# AI_MODEL_FAST=llama3.1:8b-instruct-q4_K_M

# Circuit Breaker (optional)
# CIRCUIT_BREAKER_THRESHOLD=3
# CIRCUIT_BREAKER_RESET_SEC=60
